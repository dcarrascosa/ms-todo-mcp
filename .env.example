# --- Microsoft To Do MCP configuration ---
# Copy this file to ".env" and fill in your values. NEVER commit ".env".

# Application (client) ID from your Entra ID app registration. REQUIRED.
MS_TODO_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Tenant to authenticate against. REQUIRED for work/school (single-tenant) apps.
#   - Use your tenant ID (GUID) or domain for a single-tenant app  -> recommended for SADE
#   - "organizations" = any work/school account
#   - "common"        = work/school OR personal Microsoft accounts
#   - "consumers"     = personal Microsoft accounts only
MS_TODO_TENANT_ID=organizations

# Where to store the OAuth token cache (access + refresh tokens).
# Defaults to ~/.ms_todo_mcp/token_cache.json if unset. Keep it OUT of the repo.
# MS_TODO_TOKEN_CACHE=/absolute/path/to/token_cache.json

# Default time zone applied to due dates when none is supplied (IANA name).
MS_TODO_TIMEZONE=Europe/Madrid
